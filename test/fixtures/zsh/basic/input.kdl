name "mytool"
help "A sample CLI tool for testing completions"

cmd "backup" help="The action to perform" {
    cmd "generate" help="help for generate" {
        flag "-h --help" help="Display help"
        flag "-o --to-stdout" help="Prints script"
    }
    cmd "remote" help="help for remote" {
        cmd "list" help="help for list" {
            flag "-h --help" help="Display help"
            flag "-o --to-stdout" help="Prints script"
        }
        cmd "unwrap" help="help for list" {
            flag "-h --help" help="Display help"
            flag "-o --to-stdout" help="Prints script"
            flag "-l --latest" help="Fetches latest script"

            arg "backup_name" help="The backup file name"
        }
    }
}

cmd "containers" help="help for containers" {
    cmd "list" help="help for list" {
        flag "-h --help" help="Display help"
        flag "-o --to-stdout" help="Prints script"
        flag "-n --no-headings" help="Hide headings"
    }
    cmd "mount" help="help for list" {
        flag "-h --help" help="Display help"
        flag "-o --to-stdout" help="Prints script"
        arg "<file>" help="container image file"
        arg "<file>" help="destination"
    }
}
