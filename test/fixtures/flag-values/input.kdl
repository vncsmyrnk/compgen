name "mytool"
help "mytool is a free and open source distributed version control system designed to handle everything from small to very large projects with speed and efficiency."

cmd "checkout" help="Switch branches or restore working tree files" {
    flag "-t --track <ref>" help="When creating  a  new  branch, set up \"upstream\" configuration" run="git for-each-ref --format='\"%(refname)\"' refs/heads 2>/dev/null"
}
